#!/bin/sh
set -eu

cd -P -- "$(dirname -- "$0")"

# NOTE: an earlier version of this script unconditionally `rm`-ed
# /tmp/to_do.db* before boot to recover from libsql replica drift after
# schema-change deploys. That made every cold boot ship a full DB sync from
# Turso — which, combined with `auto_stop_machines`, blew through Turso's
# sync-bandwidth allowance. We removed the wipe and pinned the machine
# always-on (see fly.toml). If a future schema-change deploy stranded the
# replica with a stale schema (symptom: `SQLite failure: no such column`),
# manual recovery is one `flyctl machine restart --app orelle`.
PHX_SERVER=true exec ./to_do start
